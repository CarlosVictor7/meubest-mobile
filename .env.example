# ================================================================
# meubest-mobile — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env.
# Variáveis com prefixo EXPO_PUBLIC_ são expostas no bundle do app.
# NUNCA coloque secrets (tokens, chaves privadas) com EXPO_PUBLIC_.
# ================================================================

# ── Firebase Client SDK ───────────────────────────────────────────
# Obtido em: Firebase Console → Configurações do Projeto → Seus apps
# Estas variáveis são PÚBLICAS — segurança garantida pelas Firestore Rules.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_FIRESTORE_DATABASE_ID=(default)

# ── meubest-api ───────────────────────────────────────────────────
# URL do backend de pagamentos/gorjetas.
# NUNCA chame Mercado Pago diretamente do app mobile.
# NUNCA coloque Access Token do Mercado Pago aqui.
#
# Opções por ambiente:
#
#   Emulador Android (AVD padrão):
#     EXPO_PUBLIC_API_URL=http://10.0.2.2:3333
#
#   Device físico ou emulador na mesma rede Wi-Fi:
#     EXPO_PUBLIC_API_URL=http://<IP_LOCAL_DO_PC>:3333
#     (ex: http://192.168.1.100:3333)
#
#   Desenvolvimento com ngrok (recomendado para testes de webhook):
#     EXPO_PUBLIC_API_URL=https://abc123.ngrok-free.app
#
#   Produção (Easypanel):
#     EXPO_PUBLIC_API_URL=https://api.meu.best
#
EXPO_PUBLIC_API_URL=http://10.0.2.2:3333

# ── Stripe (se usado) ─────────────────────────────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── EAS Build ─────────────────────────────────────────────────────
EXPO_PUBLIC_EAS_PROJECT_ID=

# ── App Variant ───────────────────────────────────────────────────
# Controla nome do app, ícone e bundle ID no app.config.js
# Valores aceitos: development | staging | production
APP_VARIANT=development
